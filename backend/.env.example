# ─── DATABASE ───────────────────────────────────────
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASS@cluster55358.xxxxx.mongodb.net/efs_store

# ─── SERVER ─────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── SECURITY ───────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_string_never_share_this_key_ever
JWT_EXPIRES_IN=8h

# ─── EMAIL (optional — for order notifications) ──────
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
